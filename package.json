{
  "name": "vite-component-library",
  "private": false,
  "version": "3.0.1",
  "packageManager": "npm@10.9.2",
  "main": "./dist/vite-component-library.umd.js",
  "module": "./dist/vite-component-library.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/vite-component-library.es.js",
      "require": "./dist/vite-component-library.umd.js"
    },
    "./styles.css": "./dist/lib.css"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "tc": "tsc --noEmit",
    "dev": "storybook dev -p 6006",
    "build": "storybook build",
    "build:lib": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "format": "npx @biomejs/biome check --write --organize-imports-enabled=true ./src",
    "test": "vitest",
    "test:cov": "vitest run --coverage",
    "prepack": "json -f package.json -I -e \"delete this.devDependencies; delete this.dependencies\""
  },
  "dependencies": {
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.39.4",
    "@storybook/addon-docs": "9.1.2",
    "@storybook/addon-links": "9.1.2",
    "@storybook/addon-themes": "9.1.2",
    "@storybook/react-vite": "9.1.2",
    "@tailwindcss/postcss": "4.2.2",
    "@tailwindcss/vite": "4.2.2",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitejs/plugin-react": "5.0.1",
    "@vitest/coverage-v8": "4.1.0",
    "autoprefixer": "10.4.27",
    "babel-loader": "10.1.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "eslint-plugin-unicorn": "^63.0.0",
    "husky": "9.1.7",
    "jsdom": "29.0.0",
    "json": "11.0.0",
    "lint-staged": "16.4.0",
    "postcss": "8.5.8",
    "prop-types": "15.8.1",
    "storybook": "9.1.2",
    "tailwindcss": "4.2.2",
    "typescript": "^5.9.3",
    "vite": "^7.1.3",
    "vite-plugin-dts": "4.5.4",
    "vitest": "4.1.0"
  },
  "peerDependencies": {
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "files": [
    "dist"
  ]
}
